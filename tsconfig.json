{
  "compilerOptions": {
    "target": "ES2022",
    "experimentalDecorators": true,
    "useDefineForClassFields": false,
    "module": "ESNext",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "skipLibCheck": true,
    /* Changed: 'node' resolution is required for backend scripts */
    "moduleResolution": "node",
    "isolatedModules": true,
    "moduleDetection": "force",
    "allowJs": true,
    "jsx": "react-jsx",
    /* Changed: Must be false to allow 'tsc' to actually create the dist files */
    "noEmit": false, 
    "esModuleInterop": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  /* Only include the files we want to compile */
  "include": ["src", "server.ts"],
  "exclude": ["node_modules", "dist"]
}
